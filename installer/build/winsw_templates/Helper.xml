<?xml version="1.0" encoding="UTF-8"?>
<!-- Secondary watchdog. It runs the same GuardianNodeWatchdog.exe and revives
     the primary watchdog; the primary revives this one. Stopping either
     requires admin rights (see the sc sdset ACL in the installer), which is
     the parent-controlled way to manage tamper resistance.
     Transparency rule: every GuardianNode service is clearly GuardianNode-
     branded. Do NOT give this (or any) service a generic/deceptive name. -->
<service>
  <id>GuardianNodeWatchdog2</id>
  <name>GuardianNode Watchdog (secondary)</name>
  <description>Part of GuardianNode parental safety monitoring. Restarts GuardianNode services if they stop. Managed by a parent/administrator.</description>
  <executable>%BASE%\agent\GuardianNodeWatchdog.exe</executable>
  <arguments>--interval 5 --peer-service GuardianNodeWatchdog</arguments>
  <workingdirectory>%BASE%\agent</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <resetfailure>1 hour</resetfailure>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
</service>
