<?xml version="1.0" encoding="UTF-8"?>
<service>
  <id>GuardianNodeAgent</id>
  <name>GuardianNode Agent</name>
  <description>GuardianNode child-safety monitoring agent</description>
  <executable>%BASE%\agent\GuardianNodeAgent.exe</executable>
  <arguments></arguments>
  <workingdirectory>%BASE%\agent</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="5 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <resetfailure>1 hour</resetfailure>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
</service>
