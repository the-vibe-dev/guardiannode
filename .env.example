# GuardianNode local backend example. Copy to .env or a protected server.env.
# Keep the backend on loopback unless you have configured a trusted VPN/TLS path.
GUARDIANNODE_DATA_DIR=local_config/dev-data
GUARDIANNODE_BIND_HOST=127.0.0.1
GUARDIANNODE_BIND_PORT=8787
GUARDIANNODE_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
GUARDIANNODE_MDNS_ENABLED=false
GUARDIANNODE_DEV_MODE=false
GUARDIANNODE_HTTPS_ONLY_COOKIES=false

# Local detection. Empty model names leave model-backed classification disabled
# until the operator selects and installs appropriate Ollama models.
GUARDIANNODE_CLASSIFIER_MODE=rules_only
GUARDIANNODE_OLLAMA_URL=http://127.0.0.1:11434
GUARDIANNODE_TEXT_MODEL=
GUARDIANNODE_VISION_MODEL=
GUARDIANNODE_TESSERACT_ENABLED=true
GUARDIANNODE_OCR_LANGUAGES=eng

# Operational defaults. Do not place SMTP passwords, tokens, or real secrets in
# a committed environment file.
GUARDIANNODE_LOG_LEVEL=INFO
GUARDIANNODE_RETENTION_CLEANUP_ENABLED=true
GUARDIANNODE_NOTIFICATION_WORKER_ENABLED=true
GUARDIANNODE_DATABASE_BACKUP_ENABLED=true

# Guardian Review is opt-in and remains unavailable until the selected provider
# is connected. Parent-friendly installs use Codex CLI with "Sign in with
# ChatGPT"; API-key mode is an advanced server deployment option.
GUARDIANNODE_GUARDIAN_REVIEW_ENABLED=false
GUARDIANNODE_GUARDIAN_REVIEW_PROVIDER=codex
GUARDIANNODE_GUARDIAN_REVIEW_MODEL=gpt-5.6
# ChatGPT-authenticated Codex uses its supported GPT-5.6 Sol alias.
GUARDIANNODE_GUARDIAN_REVIEW_CODEX_MODEL=gpt-5.6-sol
GUARDIANNODE_GUARDIAN_REVIEW_PROMPT_VERSION=guardian-review-v1
GUARDIANNODE_GUARDIAN_REVIEW_TIMEOUT_SECONDS=45
GUARDIANNODE_GUARDIAN_REVIEW_MAX_ATTEMPTS=2
GUARDIANNODE_GUARDIAN_REVIEW_ZDR_CONFIRMED=false
GUARDIANNODE_CODEX_EXECUTABLE=codex
# GUARDIANNODE_OPENAI_API_KEY (or process-level OPENAI_API_KEY) is read only
# when provider=openai. Never commit it. store=false does not by itself prove
# Zero Data Retention; set ZDR_CONFIRMED only after verifying the OpenAI project.
