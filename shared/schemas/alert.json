{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guardiannode.io/schemas/alert.json",
  "title": "Alert",
  "type": "object",
  "required": ["alert_id", "risk_id", "severity", "status", "created_at"],
  "properties": {
    "alert_id": {"type": "string"},
    "risk_id": {"type": "string"},
    "device_id": {"type": ["string", "null"]},
    "profile_id": {"type": ["string", "null"]},
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "reviewed", "false_positive", "escalated", "dismissed"]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "reviewed_by": {"type": ["string", "null"]},
    "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
    "action_taken": {"type": ["string", "null"]},
    "notes": {"type": ["string", "null"], "maxLength": 4096}
  },
  "additionalProperties": false
}
